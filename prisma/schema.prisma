generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Auth ====================

enum Role {
  ADMIN
  GERANT
  CHEF_CHANTIER
  OUVRIER
  COMMERCIAL
  ADMINISTRATIF
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(OUVRIER)
  phone         String?
  actif         Boolean   @default(true)
  accounts      Account[]
  sessions      Session[]
  depenses      Depense[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== Clients ====================

model Client {
  id          String     @id @default(cuid())
  nom         String
  prenom      String?
  email       String?
  telephone   String?
  adresse     String?
  entreprise  String?
  typeClient  String     @default("PARTICULIER")
  notes       String?    @db.Text
  chantiers   Chantier[]
  prospects   Prospect[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ==================== BTP Core ====================

enum StatutChantier {
  PROSPECT
  DEVIS_ENVOYE
  EN_COURS
  TERMINE
  ANNULE
}

model Chantier {
  id             String              @id @default(cuid())
  nom            String
  adresse        String
  type           String?
  surface        Float?
  materiaux      String?
  description    String?             @db.Text
  statut         StatutChantier      @default(PROSPECT)
  dateDebut      DateTime?
  dateFin        DateTime?
  couleur        String?
  notes          String?             @db.Text
  chefId         String?
  chef           MembreEquipe?       @relation("ChefChantier", fields: [chefId], references: [id])
  clientId       String?
  client         Client?             @relation(fields: [clientId], references: [id])
  photos         PhotoChantier[]
  estimations    Estimation[]
  affectations   ChantierMembre[]
  depenses       Depense[]
  planningEvents PlanningEvent[]
  prospects      Prospect[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model PhotoChantier {
  id          String   @id @default(cuid())
  chantierId  String
  url         String
  description String?
  chantier    Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  uploadedAt  DateTime @default(now())
}

model ChantierMembre {
  id         String       @id @default(cuid())
  chantierId String
  membreId   String
  chantier   Chantier     @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  membre     MembreEquipe @relation(fields: [membreId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([chantierId, membreId])
}

// ==================== Estimation IA ====================

model Estimation {
  id            String    @id @default(cuid())
  nom           String
  adresse       String?
  surface       Float?
  typesTravaux  String[]
  marge         Float     @default(15)
  resultatsJson Json
  chantierId    String?
  chantier      Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
}

// ==================== CRM / Pipeline ====================

enum ColonneCRM {
  TOUS_PROSPECTS
  ENVOI_DEVIS
  RELANCE_1
  RELANCE_2
  RELANCE_3
  GAGNE
  PERDU
}

model Prospect {
  id           String           @id @default(cuid())
  nom          String
  email        String?
  telephone    String?
  typeChantier String?
  notes        String?          @db.Text
  colonne      ColonneCRM       @default(TOUS_PROSPECTS)
  clientId     String?
  client       Client?          @relation(fields: [clientId], references: [id])
  chantierId   String?
  chantier     Chantier?        @relation(fields: [chantierId], references: [id])
  actions      ProspectAction[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ProspectAction {
  id         String   @id @default(cuid())
  prospectId String
  type       String
  contenu    String?  @db.Text
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  sentAt     DateTime @default(now())
}

model StyleEmailIA {
  id          String   @id @default(cuid())
  userId      String?
  exemples    Json?
  preferences Json?
  profil      String?  @db.Text
  createdAt   DateTime @default(now())
}

// ==================== Finances ====================

enum CategorieDepense {
  REPAS
  CARBURANT
  MATERIAUX
  OUTILLAGE
  TRANSPORT
  AUTRE
}

model Depense {
  id          String           @id @default(cuid())
  userId      String?
  chantierId  String?
  montant     Float
  date        DateTime         @default(now())
  fournisseur String?
  categorie   CategorieDepense @default(AUTRE)
  photoUrl    String?
  notes       String?
  user        User?            @relation(fields: [userId], references: [id])
  chantier    Chantier?        @relation(fields: [chantierId], references: [id])
  createdAt   DateTime         @default(now())
}

// ==================== Équipe ====================

model MembreEquipe {
  id           String           @id @default(cuid())
  nom          String
  prenom       String?
  email        String?
  telephone    String?
  role         String           @default("Ouvrier")
  specialite   String?
  actif        Boolean          @default(true)
  affectations ChantierMembre[]
  chefDe       Chantier[]       @relation("ChefChantier")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// ==================== Planning ====================

model PlanningEvent {
  id         String   @id @default(cuid())
  chantierId String
  dateDebut  DateTime
  dateFin    DateTime
  couleur    String?
  chantier   Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// ==================== Paramètres ====================

model Settings {
  id            String  @id @default("singleton")
  nomEntreprise String?
  siret         String?
  adresse       String?
  telephone     String?
  email         String?
  tva           Float   @default(20)
  margeDefaut   Float   @default(15)
  anthropicKey  String?
  resendKey     String?
  smtpHost      String?
  smtpPort      Int?
  smtpEmail     String?
  smtpPassword  String?
}
