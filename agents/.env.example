# URL du projet Supabase BTP Pro (ex. https://xxxxx.supabase.co)
SUPABASE_URL=

# Clé secrète Supabase (format sb_secret_..., équivalent service_role).
# NE JAMAIS exposer côté client — bypass les RLS.
SUPABASE_SECRET_KEY=

# Clé API Anthropic pour Claude (format sk-ant-api03-...)
ANTHROPIC_API_KEY=

# Token du bot Telegram (fourni par @BotFather)
TELEGRAM_BOT_TOKEN=

# ID du chat Telegram où recevoir les notifications (nombre, ex. -1001234567890)
TELEGRAM_CHAT_ID=
